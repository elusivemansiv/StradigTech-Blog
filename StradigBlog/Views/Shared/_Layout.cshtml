<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — StradigBlog</title>


    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        :root {
            --navy: #0d1b2a;
            --cream: #f5f0e8;
            --accent: #e8622a;
            --accent-light: #f4845f;
            --muted: #6b7280;
            --border: #e2ddd5;
            --card-bg: #ffffff;
            --font-display: 'Inter', sans-serif;
            --font-body: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;

        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--font-body);
            background: var(--cream);
            color: var(--navy);
            line-height: 1.7;
        }

        /* ── NAVBAR ── */
        .site-nav {
            background: rgba(13, 27, 42, 0.95);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 1000;
            height: 72px;
            box-shadow: 0 4px 30px rgba(0,0,0,0.1);
            border-bottom: 1px solid rgba(255,255,255,0.05);
            display: flex;
            align-items: center;
        }

        .nav-container {
            width: 100%;
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        /* ── LOGO ── */
        .nav-brand {
            font-family: var(--font-display);
            font-size: 1.4rem;
            font-weight: 900;
            color: white;
            text-decoration: none;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 12px;
            z-index: 1001;
            transition: transform 0.2s ease;
        }

        .nav-brand:hover {
            transform: scale(1.02);
        }

        .logo-icon {
            width: 38px;
            height: 38px;
            background: linear-gradient(135deg, #e8622a, #f4845f);
            border-radius: 11px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: white;
            transform: rotate(-5deg);
            flex-shrink: 0;
            box-shadow: 0 4px 15px rgba(232,98,42,0.4);
        }

        .nav-brand span {
            color: #e8622a;
        }

        /* ── NAV LINKS ── */
        .nav-links {
            display: flex;
            gap: 0.75rem;
            list-style: none;
            align-items: center;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .nav-links li {
            position: relative;
        }

        .nav-links a {
            color: rgba(245,240,232,0.8);
            text-decoration: none;
            font-size: 0.92rem;
            font-weight: 500;
            padding: 0.6rem 1.1rem;
            border-radius: 10px;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .nav-links a:hover {
            color: var(--cream);
            background: rgba(255,255,255,0.08);
        }

        .nav-links a.active {
            color: white;
            background: rgba(255,255,255,0.12);
        }

        .nav-btn {
            background: var(--accent) !important;
            color: white !important;
            border-radius: 10px !important;
            box-shadow: 0 4px 15px rgba(232,98,42,0.25);
        }

        .nav-btn:hover {
            background: var(--accent-light) !important;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(232,98,42,0.35);
        }

        /* ── MOBILE TOGGLE ── */
        .nav-toggle {
            display: none;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
            z-index: 1001;
            padding: 0.5rem;
            border-radius: 10px;
            transition: all 0.2s;
        }

        .nav-toggle:hover {
            background: rgba(255,255,255,0.1);
        }

        @@media (max-width: 991px) {
            .nav-toggle {
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .nav-links {
                position: fixed;
                top: 0;
                right: -100%;
                width: 300px;
                height: 100vh;
                background: var(--navy);
                flex-direction: column;
                align-items: stretch;
                padding: 100px 1.5rem 2rem;
                gap: 0.75rem;
                box-shadow: -10px 0 40px rgba(0,0,0,0.4);
                z-index: 1000;
            }

            .nav-links.active {
                right: 0;
            }

            .nav-links a {
                padding: 1rem 1.25rem;
                font-size: 1.1rem;
                background: rgba(255,255,255,0.03);
            }

            .nav-overlay {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0,0,0,0.6);
                backdrop-filter: blur(5px);
                z-index: 999;
                display: none;
                opacity: 0;
                transition: opacity 0.3s;
            }

            .nav-overlay.active {
                display: block;
                opacity: 1;
            }
        }

        /* ── MAIN CONTENT ── */
        main {
            min-height: calc(100vh - 134px);
        }

        /* ── FOOTER ── */
        .site-footer {
            background: var(--navy);
            color: rgba(245,240,232,.6);
            text-align: center;
            padding: 2.5rem 1.5rem;
            font-size: 0.85rem;
            border-top: 1px solid rgba(255,255,255,.05);
        }

        .site-footer a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 500;
        }

        /* ── UTILITY ── */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1.5rem;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.6rem 1.4rem;
            border-radius: 6px;
            font-family: var(--font-body);
            font-size: 0.875rem;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            border: none;
            transition: all 0.2s;
        }

        .btn-primary {
            background: var(--accent);
            color: white;
        }

            .btn-primary:hover {
                background: var(--accent-light);
                color: white;
                transform: translateY(-1px);
            }

        .btn-outline {
            background: transparent;
            color: var(--navy);
            border: 1.5px solid var(--navy);
        }

            .btn-outline:hover {
                background: var(--navy);
                color: var(--cream);
            }

        .btn-danger {
            background: #dc2626;
            color: white;
        }

            .btn-danger:hover {
                background: #b91c1c;
            }

        .btn-secondary {
            background: #e5e7eb;
            color: var(--navy);
        }

            .btn-secondary:hover {
                background: #d1d5db;
            }

        /* ── FORM STYLES ── */
        .form-group {
            margin-bottom: 1.25rem;
        }

        .form-label {
            display: block;
            font-weight: 500;
            font-size: 0.875rem;
            margin-bottom: 0.4rem;
            color: var(--navy);
        }

        .form-control {
            width: 100%;
            padding: 0.65rem 0.9rem;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-family: var(--font-body);
            font-size: 0.95rem;
            background: white;
            color: var(--navy);
            transition: border-color 0.2s;
            outline: none;
        }

            .form-control:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(232,98,42,.1);
            }

        textarea.form-control {
            resize: vertical;
            min-height: 180px;
        }

        /* ── PAGE HEADER ── */
        .page-header {
            background: var(--navy);
            color: var(--cream);
            padding: 3rem 0;
            margin-bottom: 2.5rem;
        }

            .page-header h1 {
                font-family: var(--font-display);
                font-size: 2.5rem;
                font-weight: 700;
            }

            .page-header p {
                color: rgba(245,240,232,.6);
                margin-top: 0.5rem;
            }

        /* ── ALERTS ── */
        .alert {
            padding: 1rem 1.25rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
        }

        .alert-danger {
            background: #fef2f2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <nav class="site-nav">
        <div class="nav-overlay" id="navOverlay"></div>
        <div class="nav-container">
            <a class="nav-brand" asp-controller="Home" asp-action="Index">
                <div class="logo-icon">
                    <i class="fas fa-bolt"></i>
                </div>
                Stradig<span>Blog</span>
            </a>

            <button class="nav-toggle" id="navToggle" aria-label="Toggle Navigation">
                <i class="bi bi-list"></i>
            </button>

            <ul class="nav-links" id="navLinks">
                <li>
                    <a asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-door"></i> Home
                    </a>
                </li>
                <li>
                    <a asp-controller="Posts" asp-action="Index">
                        <i class="bi bi-journal-text"></i> All Posts
                    </a>
                </li>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <li>
                        <a asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-grid-1x2"></i> Dashboard
                        </a>
                    </li>
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" style="display:none;">
                            @Html.AntiForgeryToken()
                        </form>
                        <a href="javascript:document.getElementById('logoutForm').submit()" class="btn" style="background:rgba(255,255,255,0.08); color:rgba(245,240,232,0.8); border:1px solid rgba(255,255,255,0.1); padding:0.6rem 1.1rem; border-radius:10px; font-size: 0.92rem;">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </a>
                    </li>
                }
                else
                {
                    <li>
                        <a asp-controller="Account" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right"></i> Login
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Account" asp-action="Register" class="nav-btn btn">
                            <i class="bi bi-person-plus"></i> Register
                        </a>
                    </li>
                }
            </ul>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <p>&copy; @DateTime.Now.Year <strong>StradigBlog</strong> — Developed By <a href="#">Mansib Ahsan</a></p>
    </footer>

    <script>
        const navToggle = document.getElementById('navToggle');
        const navLinks = document.getElementById('navLinks');
        const navOverlay = document.getElementById('navOverlay');

        if (navToggle && navLinks && navOverlay) {
            navToggle.addEventListener('click', () => {
                navLinks.classList.toggle('active');
                navOverlay.classList.toggle('active');
                const icon = navToggle.querySelector('i');
                if (navLinks.classList.contains('active')) {
                    icon.classList.replace('bi-list', 'bi-x-lg');
                } else {
                    icon.classList.replace('bi-x-lg', 'bi-list');
                }
            });

            navOverlay.addEventListener('click', () => {
                navLinks.classList.remove('active');
                navOverlay.classList.remove('active');
                navToggle.querySelector('i').classList.replace('bi-x-lg', 'bi-list');
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>