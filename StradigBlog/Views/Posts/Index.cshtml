@model IEnumerable<StradigBlog.Models.Post>
@{
    ViewData["Title"] = "All Posts";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

@section Styles {
    <style>
        .posts-header {
            background: var(--navy);
            color: var(--cream);
            padding: 3.5rem 0 2.5rem;
            margin-bottom: 3rem;
            position: relative;
            overflow: hidden;
        }

            .posts-header::before {
                content: 'BLOG';
                position: absolute;
                right: -20px;
                top: 50%;
                transform: translateY(-50%);
                font-family: var(--font-display);
                font-size: 10rem;
                font-weight: 900;
                color: rgba(255,255,255,.04);
                letter-spacing: -4px;
            }

            .posts-header h1 {
                font-family: var(--font-display);
                font-size: 2.75rem;
                font-weight: 900;
            }

            .posts-header p {
                color: rgba(245,240,232,.55);
                margin-top: .5rem;
            }

        .posts-header-row {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1.5rem;
        }

        /* TABLE */

        .posts-table-wrap {
            background: white;
            border-radius: 14px;
            border: 1px solid var(--border);
            overflow: hidden;
            box-shadow: 0 2px 20px rgba(13,27,42,.06);
            margin-bottom: 3rem;
        }

        .posts-table {
            width: 100%;
            border-collapse: collapse;
        }

            .posts-table thead {
                background: var(--navy);
                color: var(--cream);
            }

                .posts-table thead th {
                    padding: 1rem 1.25rem;
                    font-size: .75rem;
                    font-weight: 600;
                    letter-spacing: .8px;
                    text-transform: uppercase;
                    text-align: left;
                }

            .posts-table tbody tr {
                border-bottom: 1px solid var(--border);
                transition: background .15s;
            }

                .posts-table tbody tr:hover {
                    background: #faf8f5;
                }

            .posts-table td {
                padding: 1.1rem 1.25rem;
                vertical-align: middle;
                font-size: .9rem;
            }

        .td-title {
            font-family: var(--font-display);
            font-size: 1rem;
            font-weight: 700;
            color: var(--navy);
            max-width: 340px;
        }

            .td-title a {
                color: inherit;
                text-decoration: none;
            }

                .td-title a:hover {
                    color: var(--accent);
                }

        .td-excerpt {
            color: var(--muted);
            font-size: .82rem;
            margin-top: .2rem;
            display: -webkit-box;
            -webkit-line-clamp: 1;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .category-pill {
            display: inline-block;
            background: rgba(232,98,42,.1);
            color: var(--accent);
            font-size: .72rem;
            font-weight: 600;
            text-transform: uppercase;
            padding: .3rem .8rem;
            border-radius: 999px;
        }

            .category-pill.none {
                background: #f3f4f6;
                color: var(--muted);
            }

        .td-date {
            color: var(--muted);
            font-size: .82rem;
        }

        .actions-cell {
            display: flex;
            gap: .5rem;
        }

        .action-btn {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            padding: .4rem .85rem;
            border-radius: 6px;
            font-size: .78rem;
            font-weight: 500;
            text-decoration: none;
        }

        .action-btn-view {
            background: #f0f9ff;
            color: #0369a1;
        }

        .action-btn-edit {
            background: #fefce8;
            color: #854d0e;
        }

        .action-btn-delete {
            background: #fef2f2;
            color: #991b1b;
        }

        /* EMPTY STATE */

        .empty-state {
            text-align: center;
            padding: 5rem 2rem;
            color: var(--muted);
        }

            .empty-state i {
                font-size: 3.5rem;
                opacity: .25;
                display: block;
                margin-bottom: 1rem;
            }

            .empty-state h3 {
                font-family: var(--font-display);
                font-size: 1.5rem;
                color: var(--navy);
                margin-bottom: .5rem;
            }

        .count-badge {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            background: rgba(245,240,232,.1);
            color: rgba(245,240,232,.7);
            border: 1px solid rgba(245,240,232,.15);
            padding: .3rem .9rem;
            border-radius: 999px;
            font-size: .8rem;
        }

        @@media (max-width: 768px) {
            .posts-header {
                padding: 2.5rem 0 2rem;
                text-align: center;
            }

            .posts-header-row {
                flex-direction: column;
                align-items: center;
            }

            .posts-header h1 {
                font-size: 2rem;
            }

            .posts-table thead {
                display: none;
            }

            .posts-table tbody tr {
                display: block;
                padding: 1.5rem;
                border-bottom: 8px solid #f3f4f6;
            }

            .posts-table td {
                display: block;
                padding: 0.5rem 0;
                width: 100% !important;
            }

            .td-title {
                max-width: 100%;
                font-size: 1.15rem;
            }

            .td-excerpt {
                -webkit-line-clamp: 2;
                margin-bottom: 0.75rem;
            }

            .actions-cell {
                justify-content: flex-start !important;
                margin-top: 0.75rem;
                flex-wrap: wrap;
            }

            .action-btn {
                flex: 1;
                justify-content: center;
                min-width: 80px;
            }
        }
    </style>
}

<!-- HEADER -->
<div class="posts-header">
    <div class="container">

        <div class="posts-header-row">

            <div>
                <h1>All Posts</h1>
                <p>Manage and browse every article on the blog.</p>
            </div>

            <div>
                <span class="count-badge">
                    <i class="bi bi-file-text"></i>
                    @Model.Count() @(Model.Count() == 1 ? "post" : "posts")
                </span>
            </div>

        </div>
    </div>
</div>

<!-- POSTS TABLE -->

<div class="container">

    @if (!Model.Any())
    {
        <div class="posts-table-wrap">

            <div class="empty-state">
                <i class="bi bi-journal-x"></i>
                <h3>No posts found</h3>
                <p>There are no blog posts yet.</p>
            </div>

        </div>
    }
    else
    {

        <div class="posts-table-wrap">

            <table class="posts-table">

                <thead>
                    <tr>
                        <th style="width:40%">Post</th>
                        <th>Category</th>
                        <th>Date</th>
                        <th style="text-align:right">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var post in Model)
                    {
                        <tr>

                            <td class="td-title">
                                <a asp-action="Details" asp-route-id="@post.Id">@post.Title</a>

                                <div class="td-excerpt">
                                    @(post.Content?.Length > 100 ? post.Content.Substring(0, 100) + "…" : post.Content)
                                </div>
                            </td>

                            <td>

                                @if (post.Category != null)
                                {
                                    <span class="category-pill">@post.Category.Name</span>
                                }
                                else
                                {
                                    <span class="category-pill none">Uncategorized</span>
                                }

                            </td>

                            <td class="td-date">
                                <i class="bi bi-calendar3" style="margin-right:4px;"></i>
                                @post.CreatedDate.ToString("MMM dd, yyyy")
                            </td>

                            <td>

                                <div class="actions-cell" style="justify-content:flex-end;">

                                    <a asp-action="Details" asp-route-id="@post.Id" class="action-btn action-btn-view">
                                        <i class="bi bi-eye"></i> View
                                    </a>

                                    @if (User.Identity != null &&
                                                                User.Identity.IsAuthenticated &&
                                                                post.UserId == currentUserId)
                                    {

                                        <a asp-action="Edit" asp-route-id="@post.Id" class="action-btn action-btn-edit">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@post.Id" class="action-btn action-btn-delete">
                                            <i class="bi bi-trash"></i> Delete
                                        </a>

                                    }

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>
            </table>

        </div>

    }

</div>