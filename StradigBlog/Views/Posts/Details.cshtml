@model StradigBlog.Models.Post
@using System.Security.Claims

@{
    ViewData["Title"] = Model.Title;
    var currentUserId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
}

@section Styles {
    <style>
        /* ── ARTICLE HERO ── */
        .article-hero {
            background: var(--navy);
            color: var(--cream);
            padding: 4rem 0 3rem;
            position: relative;
            overflow: hidden;
        }

            .article-hero::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: radial-gradient(ellipse at 70% 50%, rgba(232,98,42,.12) 0%, transparent 60%);
                pointer-events: none;
            }

        .article-meta-top {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            position: relative;
            z-index: 1;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            color: rgba(245,240,232,.5);
            text-decoration: none;
            font-size: 0.85rem;
            transition: color 0.2s;
        }

            .back-link:hover {
                color: var(--cream);
            }

        .meta-divider {
            color: rgba(245,240,232,.2);
            font-size: 0.8rem;
        }

        .article-category-badge {
            display: inline-block;
            background: var(--accent);
            color: white;
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            padding: 0.3rem 0.9rem;
            border-radius: 999px;
        }

        .article-title {
            font-family: var(--font-display);
            font-size: clamp(2rem, 5vw, 3.25rem);
            font-weight: 900;
            line-height: 1.15;
            letter-spacing: -0.5px;
            margin-bottom: 1.5rem;
            position: relative;
            z-index: 1;
            max-width: 820px;
        }

        .article-meta-bottom {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            flex-wrap: wrap;
            position: relative;
            z-index: 1;
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            color: rgba(245,240,232,.55);
            font-size: 0.85rem;
        }

            .meta-item i {
                color: var(--accent-light);
            }

        /* ── ARTICLE LAYOUT ── */
        .article-layout {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 3rem;
            padding: 3rem 0 4rem;
        }

        @@media (max-width: 900px) {
            .article-layout {
                grid-template-columns: 1fr;
                gap: 2rem;
            }

            .article-sidebar {
                order: 2;
            }

            .article-hero {
                padding: 3rem 0 2.5rem;
            }

            .article-body {
                padding: 1.75rem;
            }
        }

        @@media (max-width: 576px) {
            .article-actions {
                flex-direction: column;
                gap: 1rem;
            }

            .article-actions .btn, 
            .article-actions .spacer {
                width: 100%;
                justify-content: center;
                display: flex;
                flex: none;
            }
        }

        /* ── ARTICLE IMAGE ── */
        .article-image-wrap {
            border-radius: 14px;
            overflow: hidden;
            margin-bottom: 2.5rem;
            box-shadow: 0 8px 40px rgba(13,27,42,.12);
            max-height: 420px;
        }

            .article-image-wrap img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        /* ── ARTICLE BODY ── */
        .article-body {
            background: white;
            border-radius: 14px;
            border: 1px solid var(--border);
            padding: 2.5rem;
            box-shadow: 0 2px 20px rgba(13,27,42,.05);
        }

        .article-content {
            font-size: 1.05rem;
            line-height: 1.85;
            color: #2d3748;
        }

            .article-content p {
                margin-bottom: 1.5rem;
            }

        /* ── ACTIONS ── */
        .article-actions {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-top: 2.5rem;
            padding-top: 2rem;
            border-top: 2px solid var(--border);
            flex-wrap: wrap;
        }

            .article-actions .spacer {
                flex: 1;
            }

        /* ── SIDEBAR ── */
        .sidebar-card {
            background: white;
            border-radius: 14px;
            border: 1px solid var(--border);
            overflow: hidden;
            margin-bottom: 1.5rem;
            box-shadow: 0 2px 12px rgba(13,27,42,.05);
        }

        .sidebar-card-header {
            background: var(--navy);
            color: var(--cream);
            padding: 0.85rem 1.25rem;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.8px;
            text-transform: uppercase;
        }

        .sidebar-card-body {
            padding: 1.25rem;
        }

        .sidebar-meta-row {
            display: flex;
            justify-content: space-between;
            padding: 0.6rem 0;
            border-bottom: 1px solid var(--border);
        }

            .sidebar-meta-row:last-child {
                border-bottom: none;
            }

        /* ── SIDEBAR ACTIONS ── */
        .sidebar-actions {
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

            .sidebar-actions .btn {
                width: 100%;
                justify-content: center;
            }
    </style>
}

<!-- HERO -->
<div class="article-hero">
    <div class="container">

        <div class="article-meta-top">
            <a asp-action="Index" class="back-link">
                <i class="bi bi-arrow-left"></i> All Posts
            </a>

            @if (Model.Category != null)
            {
                <span class="meta-divider">/</span>
                <span class="article-category-badge">@Model.Category.Name</span>
            }
        </div>

        <h1 class="article-title">@Model.Title</h1>

        <div class="article-meta-bottom">

            <span class="meta-item">
                <i class="bi bi-calendar3"></i>
                @Model.CreatedDate.ToString("MMMM dd, yyyy")
            </span>

            <span class="meta-item">
                <i class="bi bi-clock"></i>

                @{
                    var wordCount = Model.Content?.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length ?? 0;
                    var readMins = Math.Max(1, wordCount / 200);
                }

                @readMins min read
            </span>

            <span class="meta-item">
                <i class="bi bi-file-word"></i>
                @wordCount words
            </span>

        </div>
    </div>
</div>

<!-- CONTENT -->
<div class="container">
    <div class="article-layout">

        <div>

            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <div class="article-image-wrap">
                    <img src="@Model.ImagePath" alt="@Model.Title" />
                </div>
            }

            <div class="article-body">

                <div class="article-content">
                    @foreach (var para in (Model.Content ?? "No content available.").Split('\n', StringSplitOptions.RemoveEmptyEntries))
                    {
                        <p>@para</p>
                    }
                </div>

                <div class="article-actions">

                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Posts
                    </a>

                    <div class="spacer"></div>

                    @if (User.Identity != null && User.Identity.IsAuthenticated && Model.UserId == currentUserId)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline">
                            <i class="bi bi-pencil"></i> Edit Post
                        </a>

                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    }

                </div>
            </div>
        </div>

        <!-- SIDEBAR -->
        <aside class="article-sidebar">

            <div class="sidebar-card">
                <div class="sidebar-card-header">Post Info</div>

                <div class="sidebar-card-body">

                    <div class="sidebar-meta-row">
                        <span>Category</span>
                        <span>@(Model.Category?.Name ?? "Uncategorized")</span>
                    </div>

                    <div class="sidebar-meta-row">
                        <span>Published</span>
                        <span>@Model.CreatedDate.ToString("MMM dd, yyyy")</span>
                    </div>

                    <div class="sidebar-meta-row">
                        <span>Post By</span>
                        <span>@(Model.User?.UserName ?? "Unknown")</span>
                    </div>

                </div>
            </div>

            <div class="sidebar-card">

                <div class="sidebar-card-header">Quick Actions</div>

                <div class="sidebar-card-body">

                    <div class="sidebar-actions">

                        @if (User.Identity != null && User.Identity.IsAuthenticated && Model.UserId == currentUserId)
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline">
                                <i class="bi bi-pencil"></i> Edit this Post
                            </a>

                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Delete Post
                            </a>
                        }

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <a asp-action="Create" class="btn btn-primary">
                                <i class="bi bi-plus"></i> New Post
                            </a>
                        }

                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-grid"></i> All Posts
                        </a>

                    </div>
                </div>
            </div>

        </aside>

    </div>
</div>